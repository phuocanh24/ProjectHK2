<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F4F0"
    android:gravity="center"
    android:padding="32dp">

    <!-- Icon -->
    <TextView
        android:text="🎉"
        android:textSize="64sp"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Tiêu đề -->
    <TextView
        android:text="Đăng ký thành công!"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:gravity="center"
        android:layout_marginBottom="10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Mô tả -->
    <TextView
        android:text="Hồ sơ của bạn đã được tiếp nhận.\nChuyên viên sẽ liên hệ trong vòng 24 giờ."
        android:textSize="14sp"
        android:textColor="#666666"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="28dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Card tóm tắt -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="18dp"
        android:orientation="vertical"
        android:layout_marginBottom="28dp">

        <TextView
            android:text="Thông tin đăng ký"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#E8E5DC" android:layout_marginBottom="12dp"/>

        <!-- Họ tên -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="10dp">
            <TextView android:text="Họ tên" android:textSize="13sp" android:textColor="#888888"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"/>
            <TextView android:id="@+id/tvSummaryHoTen" android:text="—"
                android:textSize="13sp" android:textStyle="bold" android:textColor="#1A1A1A"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Số lượng -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="10dp">
            <TextView android:text="Số lượng" android:textSize="13sp" android:textColor="#888888"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"/>
            <TextView android:id="@+id/tvSummarySoLuong" android:text="—"
                android:textSize="13sp" android:textStyle="bold" android:textColor="#D4A017"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Kỳ hạn -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:text="Kỳ hạn" android:textSize="13sp" android:textColor="#888888"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"/>
            <TextView android:id="@+id/tvSummaryKyHan" android:text="—"
                android:textSize="13sp" android:textStyle="bold" android:textColor="#1A1A1A"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Nút về trang chủ -->
    <Button
        android:id="@+id/btnVeTrangChu"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="VỀ TRANG CHỦ"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="14sp"
        android:backgroundTint="#1A1A1A"
        android:stateListAnimator="@null"/>

</LinearLayout>