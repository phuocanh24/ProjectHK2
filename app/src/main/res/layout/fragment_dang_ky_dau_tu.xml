<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F4F0">

    <!-- Header -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="56dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Quay lại"/>

        <TextView
            android:text="Đăng ký đầu tư vàng"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </FrameLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E8E5DC"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <!-- Thông tin giá vàng -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1E1E1E"
                android:padding="16dp"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <LinearLayout android:orientation="vertical"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <TextView android:text="Giá vàng SJC hôm nay"
                        android:textSize="11sp" android:textColor="#99FFFFFF"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="85,500,000 ₫/lượng"
                        android:textSize="15sp" android:textStyle="bold"
                        android:textColor="#F5C842" android:layout_marginTop="4dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout android:orientation="vertical"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:gravity="end">
                    <TextView android:text="Tối thiểu" android:textSize="11sp"
                        android:textColor="#99FFFFFF"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="0.1 lượng" android:textSize="15sp"
                        android:textStyle="bold" android:textColor="#F5C842"
                        android:layout_marginTop="4dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Họ và tên -->
            <TextView android:text="HỌ VÀ TÊN" android:textSize="11sp"
                android:textStyle="bold" android:textColor="#888888"
                android:layout_marginBottom="6dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilHoTen"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:boxStrokeColor="#D4A017" app:hintEnabled="false">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etHoTen"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="Nguyễn Văn A" android:inputType="textPersonName"
                    android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Số điện thoại -->
            <TextView android:text="SỐ ĐIỆN THOẠI" android:textSize="11sp"
                android:textStyle="bold" android:textColor="#888888"
                android:layout_marginBottom="6dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilSoDienThoai"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:boxStrokeColor="#D4A017" app:hintEnabled="false">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSoDienThoai"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="0901 234 567" android:inputType="phone"
                    android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- CCCD -->
            <TextView android:text="CCCD / CMND" android:textSize="11sp"
                android:textStyle="bold" android:textColor="#888888"
                android:layout_marginBottom="6dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilCCCD"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:boxStrokeColor="#D4A017" app:hintEnabled="false">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCCCD"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="079XXXXXXXXX" android:inputType="number"
                    android:maxLength="12" android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Số lượng vàng -->
            <TextView android:text="SỐ LƯỢNG VÀNG (LƯỢNG)" android:textSize="11sp"
                android:textStyle="bold" android:textColor="#888888"
                android:layout_marginBottom="6dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilSoLuong"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:boxStrokeColor="#D4A017" app:hintEnabled="false">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSoLuong"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="VD: 0.5" android:inputType="numberDecimal"
                    android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Chip chọn nhanh -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupSoLuong"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:singleSelection="true"
                app:selectionRequired="false">
                <com.google.android.material.chip.Chip android:id="@+id/chip01"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0.1 lượng"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip05"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0.5 lượng"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip1"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="1 lượng"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip2"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="2 lượng"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip5"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="5 lượng"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip10"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="10 lượng"/>
            </com.google.android.material.chip.ChipGroup>

            <!-- Kỳ hạn -->
            <TextView android:text="KỲ HẠN ĐẦU TƯ" android:textSize="11sp"
                android:textStyle="bold" android:textColor="#888888"
                android:layout_marginBottom="6dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilKyHan"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:boxStrokeColor="#D4A017" app:hintEnabled="false">
                <AutoCompleteTextView android:id="@+id/actvKyHan"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="-- Chọn kỳ hạn --" android:inputType="none"
                    android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Điều khoản -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="24dp">
                <CheckBox android:id="@+id/cbDieuKhoan"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:buttonTint="#D4A017"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="6dp"
                    android:text="Tôi đồng ý với Điều khoản dịch vụ và Chính sách bảo mật của chương trình đầu tư vàng SJC."
                    android:textSize="12sp" android:textColor="#666666"
                    android:lineSpacingExtra="2dp"/>
            </LinearLayout>

            <!-- Nút xác nhận -->
            <Button
                android:id="@+id/btnXacNhan"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="XÁC NHẬN ĐĂNG KÝ"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="14sp"
                android:backgroundTint="#D4A017"
                android:stateListAnimator="@null"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>