<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TITLE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="THE COLLECTIONS"
            android:textSize="28sp"
            android:gravity="center"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:paddingTop="24dp"
            android:paddingBottom="16dp"
            android:fontFamily="serif"/>

        <!-- CATEGORY MENU -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/tabRings"
                android:text="RINGS"
                android:textStyle="bold"
                android:textSize="14sp"
                android:padding="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tabNecklaces"
                android:text="NECKLACES"
                android:textSize="14sp"
                android:padding="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tabEarrings"
                android:text="EARRINGS"
                android:textSize="14sp"
                android:padding="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tabBracelets"
                android:text="BRACELETS"
                android:textSize="14sp"
                android:padding="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>


        <!-- HERO IMAGE -->
        <FrameLayout
            android:id="@+id/layoutRings"
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:layout_margin="10dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/rings"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="bottom"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:text="ICONIC"
                    android:textColor="#D4AF37"
                    android:textSize="12sp"
                    android:letterSpacing="0.2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Rings"
                    android:textSize="36sp"
                    android:textColor="#FFFFFF"
                    android:fontFamily="serif"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <Button
                    android:id="@+id/btnExplore"
                    android:text="EXPLORE COLLECTION"
                    android:textColor="#FFFFFF"
                    android:background="@android:color/transparent"
                    android:layout_marginTop="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </FrameLayout>


        <!-- GRID COLLECTION -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:padding="10dp">

            <!-- NECKLACES -->
            <FrameLayout
                android:id="@+id/layoutNecklaces"
                android:layout_width="0dp"
                android:layout_height="180dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp">

                <ImageView
                    android:src="@drawable/necklace"
                    android:scaleType="centerCrop"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

                <TextView
                    android:text="Necklaces"
                    android:textSize="22sp"
                    android:textColor="#FFFFFF"
                    android:layout_gravity="bottom|center"
                    android:paddingBottom="10dp"
                    android:fontFamily="serif"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </FrameLayout>


            <!-- EARRINGS -->
            <FrameLayout
                android:id="@+id/layoutEarrings"
                android:layout_width="0dp"
                android:layout_height="180dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp">

                <ImageView
                    android:src="@drawable/earrings"
                    android:scaleType="centerCrop"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

                <TextView
                    android:text="Earrings"
                    android:textSize="22sp"
                    android:textColor="#FFFFFF"
                    android:layout_gravity="bottom|center"
                    android:paddingBottom="10dp"
                    android:fontFamily="serif"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </FrameLayout>


            <!-- BRACELETS -->
            <FrameLayout
                android:id="@+id/layoutBracelets"
                android:layout_width="0dp"
                android:layout_height="180dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp">

                <ImageView
                    android:src="@drawable/bracelets"
                    android:scaleType="centerCrop"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

                <TextView
                    android:text="Bracelets"
                    android:textSize="22sp"
                    android:textColor="#FFFFFF"
                    android:layout_gravity="bottom|center"
                    android:paddingBottom="10dp"
                    android:fontFamily="serif"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </FrameLayout>


            <!-- WATCHES -->
            <FrameLayout
                android:id="@+id/layoutWatches"
                android:layout_width="0dp"
                android:layout_height="180dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp">

                <ImageView
                    android:src="@drawable/watches"
                    android:scaleType="centerCrop"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

                <TextView
                    android:text="Watches"
                    android:textSize="22sp"
                    android:textColor="#FFFFFF"
                    android:layout_gravity="bottom|center"
                    android:paddingBottom="10dp"
                    android:fontFamily="serif"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </FrameLayout>

        </GridLayout>


        <!-- QUOTE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text='"Jewelry is the exclamation point of a woman’s outfit."'
            android:textStyle="italic"
            android:textSize="18sp"
            android:gravity="center"
            android:padding="24dp"/>

    </LinearLayout>

</ScrollView>